generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  generations   ComponentGeneration[]
  dailyUsage    DailyUsage[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum SkillSourceType {
  SEEDED
  GITHUB_DISCOVERED
}

enum SkillPublishStatus {
  PUBLISHED
  DISABLED
  EXCLUDED
}

enum GenerationStatus {
  SUCCEEDED
  FAILED
}

enum SyncRunStatus {
  SUCCEEDED
  FAILED
  PARTIAL
}

model Skill {
  id                   String                    @id @default(cuid())
  name                 String
  slug                 String                    @unique
  sourceType           SkillSourceType
  publishStatus        SkillPublishStatus        @default(PUBLISHED)
  sourceRepo           String?
  repoUrl              String?
  repoOwner            String?
  repoName             String?
  description          String?
  githubStars          Int                       @default(0)
  topics               String[]
  normalizedTags       String[]
  styleCues            String[]
  readmeSummary        String?
  readmeContent        String?                   @db.Text
  computedHash         String?
  hasReadme            Boolean                   @default(false)
  lastSyncedAt         DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  generationSelections GenerationSkillSelection[]

  @@index([publishStatus])
  @@index([sourceType])
}

model SkillSyncRun {
  id             String        @id @default(cuid())
  status         SyncRunStatus
  searchQuery    String?
  discoveredCount Int         @default(0)
  publishedCount Int          @default(0)
  skippedCount   Int           @default(0)
  errorMessage   String?       @db.Text
  startedAt      DateTime      @default(now())
  finishedAt     DateTime?
  createdAt      DateTime      @default(now())
}

model ComponentGeneration {
  id             String                     @id @default(cuid())
  userId         String?
  guestId        String?
  componentType  String
  status         GenerationStatus          @default(SUCCEEDED)
  model          String
  promptSnapshot Json
  resultCode     String                    @db.Text
  previewPayload Json
  rationale      String?                   @db.Text
  errorMessage   String?                   @db.Text
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  user           User?                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedSkills GenerationSkillSelection[]

  @@index([userId, createdAt])
  @@index([guestId, createdAt])
}

model GenerationSkillSelection {
  generationId String
  skillId      String
  generation   ComponentGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  skill        Skill               @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@id([generationId, skillId])
}

model DailyUsage {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  usedCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model CatalogRuleConfig {
  id                String   @id @default(cuid())
  minStars          Int      @default(1000)
  requiredTopics    String[]
  readmeKeywords    String[]
  autoPublishEnabled Boolean @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
